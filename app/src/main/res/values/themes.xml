<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Odak" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/odak_background</item>
        <item name="android:statusBarColor">@color/odak_background</item>
        <item name="android:navigationBarColor">@color/odak_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="WidgetRow">
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/widget_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>
</resources>
